{
  "name": "typeorm-test-factory",
  "version": "0.1.0",
  "description": "Version-safe test data factories for TypeORM. Define factories once, create realistic entities in integration and e2e tests — without coupling to a specific TypeORM version.",
  "keywords": [
    "typeorm",
    "factory",
    "seed",
    "seeding",
    "testing",
    "integration-test",
    "e2e",
    "test-data",
    "fixtures",
    "factory-bot"
  ],
  "author": "Henrique Weiand",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest",
    "test:cov": "jest --coverage",
    "release": "release-it",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "typeorm": ">=0.2.0"
  },
  "peerDependenciesMeta": {
    "typeorm": {
      "optional": true
    }
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "better-sqlite3": "^11.0.0",
    "jest": "^29.5.0",
    "pg": "^8.11.0",
    "reflect-metadata": "^0.2.0",
    "release-it": "^20.2.0",
    "ts-jest": "^29.1.0",
    "typeorm": "^0.3.20",
    "typescript": "^5.1.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ]
  }
}

{
  "name": "typeorm-test-factory",
  "version": "0.2.3",
  "description": "Version-safe test data factories for TypeORM. Define factories once, create realistic entities in integration and e2e tests — without coupling to a specific TypeORM version.",
  "keywords": [
    "typeorm",
    "factory",
    "seed",
    "seeding",
    "testing",
    "integration-test",
    "e2e",
    "test-data",
    "fixtures",
    "factory-bot"
  ],
  "author": "Henrique Weiand",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nestjsninja/typeorm-test-factory.git"
  },
  "bugs": {
    "url": "https://github.com/nestjsninja/typeorm-test-factory/issues"
  },
  "homepage": "https://github.com/nestjsninja/typeorm-test-factory#readme",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "jest",
    "test:cov": "jest --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "release": "release-it",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "peerDependencies": {
    "typeorm": ">=0.2.0"
  },
  "peerDependenciesMeta": {
    "typeorm": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/sql.js": "^1.4.9",
    "eslint": "^10.5.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "^29.5.0",
    "pg": "^8.11.0",
    "reflect-metadata": "^0.2.0",
    "release-it": "^20.2.0",
    "sql.js": "^1.10.0",
    "ts-jest": "^29.1.0",
    "typeorm": "^0.3.20",
    "typescript": "^5.1.3",
    "typescript-eslint": "^8.62.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ]
  }
}
